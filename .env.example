# ====================================================================
# ChartsonBase: Environment Configuration
# Add credentials to activate real Circle Developer-Controlled Wallets API
# ====================================================================

# Port for the Node.js Express server to listen on
PORT=3000

# Your Coinbase Developer Platform (CDP) API Key Name (e.g. organizations/.../apiKeys/...)
CDP_API_KEY_NAME=

# Your CDP API Key Private Key (in PEM format starting with -----BEGIN EC PRIVATE KEY-----)
CDP_API_KEY_PRIVATE_KEY=

# Optional: Persisted CDP Developer Wallet ID (if importing an existing wallet)
CDP_WALLET_ID=

# Merchant Wallet Address (where USDC payments will be received on Base Sepolia)
# Defaults to 0x05c950D2EE2507678c71492a27eE1fe593CAC546
DESTINATION_WALLET_ADDRESS=

# USDC Contract Token Address on Base Sepolia
# Defaults to 0x036CbD53842c5426634e7929541eC2318f3dCF7e
USDC_TOKEN_ADDRESS=

# Gemini AI API Key for chart image analysis
GEMINI_API_KEY=
